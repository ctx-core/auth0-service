{
	"name": "@ctx-core/auth0-service",
	"version": "4.5.356",
	"description": "ctx-core auth0 ui component & express endpoints",
	"keywords": [
		"ctx-core",
		"auth0"
	],
	"homepage": "https://github.com/ctx-core/auth0-service#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/auth0-service/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/auth0-service.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-auth0-service@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"./auth0__access_token_o__new",
		"./auth0__change_password__POST",
		"./auth0__header__authorization__access_token_o__validate",
		"./auth0__header__authorization__email__validate",
		"./auth0__header__authorization__user_id__validate",
		"./auth0__jwks_cert__new",
		"./auth0__jwks_x5c__new"
	],
	"types": "./index.d.ts",
	"exports": {
		".": {
			"default": "./index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"@ctx-core/auth0": "*",
		"@ctx-core/auth0-management": "*",
		"@ctx-core/jwt": "*",
		"@ctx-core/logger": "^9.2.13",
		"ctx-core": "*",
		"jsonwebtoken": "^9.0.3"
	},
	"devDependencies": {
		"@types/auth0": "^3.3.11",
		"@types/auth0-js": "^9.21.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/trouter": "^3.1.4",
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}
